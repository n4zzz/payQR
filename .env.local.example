# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Without these, the app runs on built-in demo data (visit /amir and /s/demo).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of the app (no trailing slash) — used for displayed links.
# Dev: http://localhost:3000  ·  Prod: your Vercel URL (or custom domain later).
NEXT_PUBLIC_SITE_URL=

# Server-only. Never expose to the browser. Used sparingly for admin tasks.
SUPABASE_SERVICE_ROLE_KEY=
