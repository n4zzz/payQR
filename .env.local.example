# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Without these, the app runs on built-in demo data (visit /amir and /s/demo).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the browser. Used sparingly for admin tasks.
SUPABASE_SERVICE_ROLE_KEY=
